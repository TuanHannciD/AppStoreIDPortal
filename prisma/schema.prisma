generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  engineType             = "client"
  runtime                = "nodejs"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

enum ShareLinkDeleteStatus {
  DELETED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shareLinks ShareLink[]
}

model ShareLink {
  id             String  @id @default(cuid())
  code           String  @unique
  appLabel       String
  appDescription String?

  apiUrl    String?
  apiMethod String? @default("GET")
  apiKey    String?
  apiAppId  String?
  apiConfig Json?

  note            String?
  expiresAt       DateTime?
  rateEnabled     Boolean   @default(true)
  rateWindowSec   Int       @default(60)
  rateMaxRequests Int       @default(30)
  consumeOnVerify Boolean   @default(false)

  ownerId   String?
  owner     User?    @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  passes     SharePass[]
  authLogs   ShareAuthLog[]
  deleteLogs ShareLinkDeleteLog[]

  @@index([createdAt])
  @@index([ownerId])
}

model SharePass {
  id             String         @id @default(cuid())
  shareLinkId    String
  shareLink      ShareLink      @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  passwordHash   String
  label          String?
  quotaTotal     Int
  quotaUsed      Int            @default(0)
  revokedAt      DateTime?
  reason         String?
  expiresAt      DateTime?
  lastVerifiedAt DateTime?
  lastRevealedAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  authLogs       ShareAuthLog[]

  @@index([shareLinkId])
  @@index([revokedAt])
}

model ShareAuthLog {
  id             String     @id @default(cuid())
  shareLinkId    String?
  shareLink      ShareLink? @relation(fields: [shareLinkId], references: [id], onDelete: SetNull)
  shareLinkCode  String?
  sharePassId    String?
  sharePass      SharePass? @relation(fields: [sharePassId], references: [id], onDelete: SetNull)
  sharePassLabel String?
  action         String
  success        Boolean
  message        String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime   @default(now())

  @@index([shareLinkId, createdAt])
  @@index([sharePassId, createdAt])
  @@index([action, createdAt])
}

model ShareLinkDeleteLog {
  id                String                @id @default(cuid())
  actorUserId       String?
  actorEmail        String?
  shareLinkId       String?
  shareLink         ShareLink?            @relation(fields: [shareLinkId], references: [id], onDelete: SetNull)
  shareLinkCode     String
  appLabel          String?
  reason            String?
  status            ShareLinkDeleteStatus
  dependencySummary Json?
  createdAt         DateTime              @default(now())

  @@index([shareLinkId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([status, createdAt])
}
