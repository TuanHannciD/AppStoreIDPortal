// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  engineType             = "client"
  runtime                = "nodejs"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider = "postgresql"
}

// schema.prisma (core tables)

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  role     Role   @default(SUPER_ADMIN)

  apps App[]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model App {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  packageType String
  description String?
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sharePages SharePage[]
}

model SharePage {
  id    String @id @default(cuid())
  code  String @unique
  appId String
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  note      String?
  expiresAt DateTime?

  // Policy chung cho share page (áp lên tất cả pass của page này)
  // Nếu bạn muốn mỗi pass có policy riêng, chuyển các field này xuống SharePass.
  rateEnabled     Boolean @default(true)
  rateWindowSec   Int     @default(60) // vd 60
  rateMaxRequests Int     @default(30) // vd 30

  // Quota mặc định cấp cho mỗi pass (mỗi user)
  passQuotaTotal Int @default(50)

  // Hành vi trừ lượt khi submit pass
  // Khách yêu cầu "mỗi lần nhập pass lại trừ" => true
  consumeOnVerify Boolean @default(true)
  ownerId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  passes SharePass[]
  logs   ShareAuthLog[]
}

model SharePass {
  id          String    @id @default(cuid())
  sharePageId String
  sharePage   SharePage @relation(fields: [sharePageId], references: [id], onDelete: Cascade)

  // Password không lưu plaintext; lưu hash
  passwordHash String

  // Metadata để admin dễ quản lý pass
  label          String?
  
  // Quota theo pass (= theo user)
  quotaTotal Int
  quotaUsed  Int @default(0)

  // Trạng thái thu hồi (hết lượt thì revoke)
  revokedAt DateTime?
  reason    String? // "QUOTA_EXHAUSTED", "ADMIN_REVOKED", ...

  // Tuỳ chọn: expire theo pass riêng (nếu cần)
  expiresAt DateTime?

  // Theo dõi
  lastVerifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  logs ShareAuthLog[]

  @@index([sharePageId])
  @@index([revokedAt])
}

model ShareAuthLog {
  id          String    @id @default(cuid())
  sharePageId String
  sharePage   SharePage @relation(fields: [sharePageId], references: [id], onDelete: Cascade)

  sharePassId String?
  sharePass   SharePass? @relation(fields: [sharePassId], references: [id], onDelete: SetNull)

  // VERIFY_PASS / REVEAL / API_CALL / RATE_LIMIT_BLOCK / QUOTA_BLOCK ...
  action  String
  success Boolean
  message String?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([sharePageId, createdAt])
  @@index([sharePassId, createdAt])
}
